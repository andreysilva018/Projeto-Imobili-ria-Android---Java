<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaInicialActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="#00545454"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:background="@drawable/logo_borda"
                    android:contentDescription="@string/desc_logo"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/logo" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/nome_imobiliaria"
                android:textAlignment="center"
                android:textColor="#2196F3"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/view"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="12dp"
                android:background="#185FA5"/>

            <TextView
                android:id="@+id/txtSlogan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="40dp"
                android:layout_marginTop="12dp"
                android:lineSpacingMultiplier="1.6"
                android:text="@string/slogan_imobiliaria"
                android:textAlignment="center"
                android:textColor="#00BCD4"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnAcessar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="32dp"
                android:text="@string/btn_acessar"
                android:textSize="15sp"
                android:backgroundTint="#185FA5"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>