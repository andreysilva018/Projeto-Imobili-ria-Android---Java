<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FB"
    tools:context=".TelaLocalizacaoActivity"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#185FA5"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginBottom="8dp"
                android:alpha="0.85"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_location_white" />

            <TextView
                android:id="@+id/txtOnde_Morar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_onde_morar"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Informe sua cidade e estado"
                android:textColor="#B3D4F5"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CIDADE"
                android:textSize="11sp"
                android:textColor="#8e939c"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtCidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="addressCity"
                android:background="@drawable/borda_redonda"
                android:hint="@string/nome_cidade"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="#3871c7"
                android:textColorHighlight="#2196F3"
                tools:ignore="TextContrastCheck" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADO (UF)"
                android:textSize="11sp"
                android:textColor="#8e939c"
                android:letterSpacing="0.08"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/listasuspensa_uf"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/borda_redonda"
                android:entries="@array/listasuspensa_uf"
                android:padding="12dp"
                android:theme="@style/SpinnerStyle"
                android:textColor="#8e939c"/>

            <Button
                android:id="@+id/btnEnviar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="@string/btn_enviar"
                android:textSize="15sp"
                android:backgroundTint="#185FA5"
                app:cornerRadius="12dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>