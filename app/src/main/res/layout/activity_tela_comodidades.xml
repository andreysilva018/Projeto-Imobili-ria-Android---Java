<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FB"
    android:fillViewport="true"
    tools:context=".TelaComodidadesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#185FA5"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="⭐"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comodidades"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Selecione o que deseja no imóvel"
                android:textColor="#B3D4F5"
                android:textSize="13sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPCIONAIS DESEJADOS"
                android:textSize="11sp"
                android:textColor="#8e939c"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp"/>

            <CheckBox
                android:id="@+id/chkPiscina"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Piscina"
                android:textColor="#8e939c"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/spinner_borda_redonda"
                android:buttonTint="#185FA5"/>

            <CheckBox
                android:id="@+id/chkAreaGourmet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Área Gourmet"
                android:textColor="#8e939c"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/spinner_borda_redonda"
                android:buttonTint="#185FA5"/>

            <CheckBox
                android:id="@+id/chkLavanderia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lavanderia"
                android:textColor="#8e939c"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/spinner_borda_redonda"
                android:buttonTint="#185FA5"/>

            <CheckBox
                android:id="@+id/chkChurrasqueira"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Churrasqueira"
                android:textColor="#8e939c"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/spinner_borda_redonda"
                android:buttonTint="#185FA5"/>

            <CheckBox
                android:id="@+id/chkVaranda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Varanda"
                android:textColor="#8e939c"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/spinner_borda_redonda"
                android:buttonTint="#185FA5"/>

            <CheckBox
                android:id="@+id/chkAcademia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Academia"
                android:textColor="#8e939c"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/spinner_borda_redonda"
                android:buttonTint="#185FA5"/>

            <Button
                android:id="@+id/btnFinalizar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Finalizar"
                android:textSize="15sp"
                android:backgroundTint="#185FA5"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>